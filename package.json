{
	"name": "svelte-kit-cric",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "npm run prepare && vite dev",
		"build": "npm run prepare && vite build",
		"preview": "vite preview",
		"prepare": "npm run smui-theme-light && npm run smui-theme-dark",
		"smui-theme-light": "smui-theme compile static/smui.css -i src/theme",
		"smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark"
	},
	"devDependencies": {
		"@smui/button": "^9.0.1",
		"@smui/circular-progress": "^9.0.1",
		"@smui/card": "^9.0.1",
		"@smui/checkbox": "^9.0.1",
		"@smui/chips": "^9.0.1",
		"@smui/data-table": "^9.0.1",
		"@smui/dialog": "^9.0.1",
		"@smui-extra/accordion": "^9.0.1",
		"@smui/fab": "^9.0.1",
		"@smui/form-field": "^9.0.1",
		"@smui/icon-button": "^9.0.1",
		"@smui/layout-grid": "^9.0.1",
		"@smui/radio": "^9.0.1",
		"@smui/tab": "^9.0.1",
		"@smui/tab-bar": "^9.0.1",
		"@smui/textfield": "^9.0.1",
		"@smui/top-app-bar": "^9.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.66.0",
		"smui-theme": "^9.0.1",
		"svelte": "^5.56.3",
		"vite": "^8.0.16"
	},
	"type": "module",
	"dependencies": {
		"axios": "^1.18.0"
	},
	"overrides": {
		"smui-theme": {
			"yargs": "^18.0.0"
		}
	}
}
